Table "ФРАГМЕНТЫ" [headercolor: #175e7a] {
	id integer [ pk, increment, not null ]
	RAW_TEXT text [ not null, note: 'исходная цитата / кусок источника' ]
	normalized_text text [ not null, note: 'очищенная версия: пунктуация, структура, краткое упорядочивание;' ]
	location text [ not null, note: 'где это находится в источнике.' ]

	Note: 'Фрагмент — это нормализованный, но доказательно привязанный смысловой кусок одного источника.'
}

