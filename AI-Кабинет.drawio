  <diagram name="AI-кабинет — память клиента" id="ai-cabinet-memory-workflow">
    <mxGraphModel dx="3200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3200" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
