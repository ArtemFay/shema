        </mxCell>
        <mxCell id="subtitle" value="MVP: текстовый поток после сессии. ИИ предлагает обновления памяти, но не меняет память молча." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;align=center;verticalAlign=middle" vertex="1" parent="1">
