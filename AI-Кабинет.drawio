          <mxGeometry x="840" y="315" width="200" height="85" as="geometry" />
        </mxCell>
        <mxCell id="extract_evidence" value="Evidence refs&#xa;ссылка на реплику и фрагменты" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="840" y="430" width="200" height="75" as="geometry" />
        </mxCell>
        <mxCell id="extract_dedup" value="Дедупликация, уверенность,&#xa;версии карточек" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="840" y="535" width="200" height="75" as="geometry" />
