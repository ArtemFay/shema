        <UserObject label="&lt;b&gt;Скриптовая фрагментация&lt;/b&gt;&lt;br&gt;raw fragments [0001]–[9999]&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;speaker / timestamp / blank line / hard limit&lt;/font&gt;" tooltip="Скриптовая фрагментация:&#xa;детерминированная raw-нарезка. Скрипт не понимает смысл и не чистит текст. Новый fragment создается при смене speaker, новом timestamp-блоке, пустой строке между абзацами при отсутствии speaker labels или при превышении hard limit. Одинарный перенос строки не является новой границей. Выход: fragment_id, raw_text, speaker, char range, line range, timestamps." mode="tooltip" owner="script" layer="raw" boundary_rules="speaker_change|timestamp_block|blank_line_without_speaker|hard_limit" do_not_do="no semantic grouping; no rewriting; no deletion" output_fields="fragment_id; raw_text; speaker; char_start; char_end; line_start; line_end; timestamp_start; timestamp_end" id="prep_fragment">
          <mxCell parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=14;fontStyle=1" vertex="1">
            <mxGeometry height="88" width="200" x="450" y="315" as="geometry" />
          </mxCell>
