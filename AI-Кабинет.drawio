        <mxCell id="zone_storage" value="4. Хранилища памяти" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=18;fontStyle=1;align=center;verticalAlign=top;spacingTop=12" vertex="1" parent="1">
          <mxGeometry x="1160" y="150" width="360" height="690" as="geometry" />
        </mxCell>
        <mxCell id="store_client" value="Карточка клиента / case&#xa;person, relationship, case formulation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1230" y="220" width="220" height="75" as="geometry" />
