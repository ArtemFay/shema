        <mxCell id="prep_original" value="Оригинал сессии&#xa;source_id + timestamps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="450" y="220" width="200" height="70" as="geometry" />
        </mxCell>

        <UserObject id="prep_fragment" label="&lt;b&gt;Скриптовая фрагментация&lt;/b&gt;&lt;br&gt;raw fragments [0001]–[9999]&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;speaker / timestamp / blank line / hard limit&lt;/font&gt;" tooltip="Скриптовая фрагментация: детерминированная raw-нарезка. Скрипт не понимает смысл и не чистит текст. Новый fragment создается при смене speaker, новом timestamp-блоке, пустой строке между абзацами при отсутствии speaker labels или при превышении hard limit. Одинарный перенос строки не является новой границей. Выход: fragment_id, raw_text, speaker, char range, line range, timestamps." mode="tooltip" owner="script" layer="raw" boundary_rules="speaker_change|timestamp_block|blank_line_without_speaker|hard_limit" do_not_do="no semantic grouping; no rewriting; no deletion" output_fields="fragment_id; raw_text; speaker; char_start; char_end; line_start; line_end; timestamp_start; timestamp_end">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=14;fontStyle=1" vertex="1" parent="1">
            <mxGeometry x="450" y="315" width="200" height="88" as="geometry" />
          </mxCell>
        </UserObject>

        <mxCell id="prep_clean" value="Первичная LLM-очистка&#xa;ASR, пунктуация, роли" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="450" y="430" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="prep_assembly" value="Сборка реплик / смысловых отрезков&#xa;source_fragment_ids сохраняются" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="450" y="540" width="200" height="90" as="geometry" />
        </mxCell>

        <mxCell id="zone_extract" value="3. Извлечение памяти" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=18;fontStyle=1;align=center;verticalAlign=top;spacingTop=12" vertex="1" parent="1">
          <mxGeometry x="780" y="150" width="320" height="520" as="geometry" />
