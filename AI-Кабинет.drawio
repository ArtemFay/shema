        <mxCell id="zone_prepare" value="2. Подготовка текста" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=18;fontStyle=1;align=center;verticalAlign=top;spacingTop=12" vertex="1" parent="1">
          <mxGeometry x="380" y="150" width="340" height="520" as="geometry" />
