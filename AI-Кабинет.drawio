          <mxGeometry x="1230" y="320" width="220" height="75" as="geometry" />
        </mxCell>
        <mxCell id="store_semantic" value="Semantic memory&#xa;semantic_items + revisions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1230" y="420" width="220" height="75" as="geometry" />
        </mxCell>
        <mxCell id="store_evidence" value="Доказательная база&#xa;evidence_refs до первоисточника" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="1230" y="520" width="220" height="75" as="geometry" />
        </mxCell>
        <mxCell id="store_index" value="Индексы поиска&#xa;JSONB + FTS + pgvector" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="1230" y="620" width="220" height="75" as="geometry" />
        </mxCell>
        <mxCell id="store_policy" value="Правило безопасности&#xa;ИИ предлагает изменения,&#xa;специалист утверждает" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1230" y="720" width="220" height="85" as="geometry" />
        </mxCell>

        <mxCell id="zone_retrieval" value="5. Поиск и подготовка ответа" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=18;fontStyle=1;align=center;verticalAlign=top;spacingTop=12" vertex="1" parent="1">
          <mxGeometry x="1580" y="150" width="330" height="520" as="geometry" />
        </mxCell>
        <mxCell id="retrieval_query" value="Запрос специалиста&#xa;перед новой сессией" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="1645" y="220" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="retrieval_search" value="Recall / поиск памяти&#xa;семантика + фильтры + история" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1645" y="320" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="retrieval_context" value="Сбор контекста&#xa;факты, гипотезы, риски, задачи" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="1645" y="430" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="retrieval_answer" value="Ответ ИИ специалисту&#xa;подготовка к действию" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1645" y="540" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="zone_fragment_docs" value="8. Документация блока «Скриптовая фрагментация»" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf3ff;strokeColor=#4f81bd;fontSize=18;fontStyle=1;align=center;verticalAlign=top;spacingTop=12" vertex="1" parent="1">
          <mxGeometry x="1980" y="150" width="1130" height="720" as="geometry" />
        </mxCell>
        <mxCell id="fragment_docs_caption" value="Ниже показаны 3 способа хранить подробное описание правил скриптовой фрагментации внутри draw.io: tooltip, metadata и отдельная страница схемы." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;align=center" vertex="1" parent="1">
          <mxGeometry x="2050" y="195" width="990" height="50" as="geometry" />
        </mxCell>

        <UserObject id="frag_tooltip_demo" label="&lt;b&gt;Скриптовая фрагментация&lt;/b&gt;&lt;br&gt;Вариант A: Tooltip&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;краткая оперативная памятка при hover&lt;/font&gt;" tooltip="1) Скрипт не понимает смысл и не чистит текст. 2) Базовая единица — реплика говорящего. 3) Новый fragment: смена speaker, новый timestamp-блок, пустая строка между абзацами без speaker labels, превышение hard limit. 4) Одинарный перенос строки не создает новый fragment. 5) Длинная реплика режется по . ? ! ; , затем по пробелу перед лимитом. 6) Ничего не удалять и не переписывать. 7) Выход: fragment_id + координаты в исходнике." mode="tooltip">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4f81bd;fontSize=14;fontStyle=1" vertex="1" parent="1">
            <mxGeometry x="2040" y="280" width="280" height="100" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="frag_tooltip_note" value="Редактирование пояснения:&lt;br&gt;&lt;b&gt;Edit &gt; Edit Tooltip&lt;/b&gt; или &lt;b&gt;Alt+Shift+T&lt;/b&gt;.&lt;br&gt;Что хранить: краткие правила, которые нужно быстро увидеть при наведении.&lt;br&gt;Содержимое для нашего кейса: что делает скрипт, какие границы нового fragment, что делать нельзя, какой минимальный output ожидается." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#4f81bd;fontSize=13;align=left;spacing=8" vertex="1" parent="1">
          <mxGeometry x="2040" y="400" width="280" height="250" as="geometry" />
        </mxCell>

        <UserObject id="frag_metadata_demo" label="&lt;b&gt;Скриптовая фрагментация&lt;/b&gt;&lt;br&gt;Вариант B: Metadata&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;структурированные свойства блока&lt;/font&gt;" owner="script" layer="raw" input_unit="replica_or_paragraph" new_fragment_when="speaker_change|timestamp|blank_line|hard_limit" one_newline_rule="keep_inside_fragment" hard_limit_chars="1200" target_chars="300-800" split_order="sentence; semicolon; comma; space; char" prohibited_actions="no_semantic_grouping; no_cleanup; no_rewrite; no_drop" output_fields="fragment_id; source_id; speaker; raw_text; char_start; char_end; line_start; line_end; timestamp_start; timestamp_end">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4f81bd;fontSize=14;fontStyle=1" vertex="1" parent="1">
            <mxGeometry x="2405" y="280" width="280" height="100" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="frag_metadata_note" value="Редактирование метаданных:&lt;br&gt;&lt;b&gt;Edit Data&lt;/b&gt; или &lt;b&gt;Ctrl+M / Cmd+M&lt;/b&gt;.&lt;br&gt;Что хранить: machine-readable свойства блока.&lt;br&gt;Для нашей задачи здесь должны лежать: boundary rules, лимиты длины, запреты, порядок split, поля output и тип слоя = raw.&lt;br&gt;Это удобно как формальная спецификация для скрипта." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#4f81bd;fontSize=13;align=left;spacing=8" vertex="1" parent="1">
          <mxGeometry x="2405" y="400" width="280" height="250" as="geometry" />
        </mxCell>

        <UserObject id="frag_page_demo" label="&lt;b&gt;Скриптовая фрагментация&lt;/b&gt;&lt;br&gt;Вариант C: Отдельная страница схемы&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;полный регламент и логика шага&lt;/font&gt;" tooltip="Подробный регламент вынесен на отдельную страницу: 'Скриптовая фрагментация — регламент'. Там можно хранить полный текст правил, псевдо-алгоритм, проверки целостности и структуру output." mode="page">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4f81bd;fontSize=14;fontStyle=1" vertex="1" parent="1">
            <mxGeometry x="2770" y="280" width="280" height="100" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="frag_page_note" value="Отдельная схема / страница:&lt;br&gt;лучший вариант для полного регламента.&lt;br&gt;Что хранить: определение этапа, что делает и не делает скрипт, правила начала нового fragment, правила split длинной реплики, формат output, контрольные проверки, примеры.&lt;br&gt;На странице 2 это уже развернуто." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#4f81bd;fontSize=13;align=left;spacing=8" vertex="1" parent="1">
          <mxGeometry x="2770" y="400" width="280" height="250" as="geometry" />
        </mxCell>

        <mxCell id="fragment_summary_note" value="Рекомендуемая практика: основной рабочий блок хранит и tooltip, и metadata. А отдельная страница схемы хранит полный регламент. Тогда внутри draw.io есть и быстрый просмотр, и формальная спецификация, и полноценная документация." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;align=left;spacing=8" vertex="1" parent="1">
          <mxGeometry x="2140" y="690" width="810" height="110" as="geometry" />
        </mxCell>

