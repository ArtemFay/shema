<mxfile host="app.diagrams.net" agent="ChatGPT" pages="2">
  <diagram name="AI-кабинет — память клиента" id="ai-cabinet-memory-workflow">
    <mxGraphModel dx="2600" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2600" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="AI-кабинет: схема профессиональной памяти клиента" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=28;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="420" y="30" width="1760" height="50" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Главный принцип: память — не summary, а доказательная картотека кейса. Каждый вывод связан с исходным фрагментом." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;align=center" vertex="1" parent="1">
          <mxGeometry x="470" y="90" width="1660" height="50" as="geometry" />
        </mxCell>

        <mxCell id="phase_1" value="1. Источник" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="70" y="190" width="230" height="80" as="geometry" />
        </mxCell>
        <UserObject id="phase_2" label="&lt;b&gt;2. Скриптовая&lt;br&gt;фрагментация&lt;/b&gt;" tooltip="Детерминированная raw-нарезка скриптом. Не LLM. Скрипт не чистит и не интерпретирует смысл. Новый fragment создается при смене speaker, timestamp-блоке, пустой строке между абзацами без speaker labels или hard limit. Одинарный перенос строки не является границей. Выход: fragment_id, raw_text, speaker, char/line ranges, timestamps." owner="script" layer="raw" boundary_rules="speaker_change|timestamp_block|blank_line_without_speaker|hard_limit" one_newline_rule="keep_inside_fragment" hard_limit_chars="1200" target_chars="300-800" split_order="sentence; semicolon; comma; space; char" prohibited_actions="no_cleanup; no_semantic_grouping; no_rewrite; no_drop" output_fields="fragment_id; source_id; speaker; raw_text; char_start; char_end; line_start; line_end; timestamp_start; timestamp_end">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=18;fontStyle=1" vertex="1" parent="1">
            <mxGeometry x="390" y="190" width="230" height="80" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="phase_3" value="3. LLM-очистка" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="710" y="190" width="230" height="80" as="geometry" />
        </mxCell>
        <mxCell id="phase_4" value="4. Извлечение памяти" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1030" y="190" width="230" height="80" as="geometry" />
        </mxCell>
        <mxCell id="phase_5" value="5. Проверка специалистом" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1350" y="190" width="230" height="80" as="geometry" />
        </mxCell>
        <mxCell id="phase_6" value="6. Память клиента" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1670" y="190" width="230" height="80" as="geometry" />
        </mxCell>
        <mxCell id="phase_7" value="7. Recall / ответ ИИ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1990" y="190" width="230" height="80" as="geometry" />
        </mxCell>

        <mxCell id="d1" value="Транскрипт, заметки, анкеты, документы. Raw source сохраняется без потери первоисточника." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=14;align=left;spacing=10" vertex="1" parent="1"><mxGeometry x="50" y="330" width="270" height="150" as="geometry" /></mxCell>
        <mxCell id="d2" value="Скрипт создает стабильные raw fragments [0001]–[9999]. Границы: speaker, timestamp, пустая строка без speaker labels, hard limit. Не чистит текст и не ищет смысл." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=14;align=left;spacing=10" vertex="1" parent="1"><mxGeometry x="370" y="330" width="270" height="150" as="geometry" /></mxCell>
        <mxCell id="d3" value="LLM получает пакет raw fragments и делает санитарную очистку: ASR, пунктуация, роли, смысловая сборка. Обязана сохранять source_fragment_ids." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=14;align=left;spacing=10" vertex="1" parent="1"><mxGeometry x="690" y="330" width="270" height="150" as="geometry" /></mxCell>
        <mxCell id="d4" value="Из чистых сегментов извлекаются карточки: факт, гипотеза, вопрос, задача, паттерн. Каждая карточка получает evidence refs." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=14;align=left;spacing=10" vertex="1" parent="1"><mxGeometry x="1010" y="330" width="270" height="150" as="geometry" /></mxCell>
        <mxCell id="d5" value="ИИ предлагает изменения памяти. Специалист принимает, исправляет или отклоняет. Без утверждения память не меняется." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=14;align=left;spacing=10" vertex="1" parent="1"><mxGeometry x="1330" y="330" width="270" height="150" as="geometry" /></mxCell>
        <mxCell id="d6" value="Хранилища: client case, sessions, semantic_items, revisions, evidence_refs, JSONB/FTS/pgvector indexes." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=14;align=left;spacing=10" vertex="1" parent="1"><mxGeometry x="1650" y="330" width="270" height="150" as="geometry" /></mxCell>
        <mxCell id="d7" value="Перед новой сессией ИИ ищет релевантную память, собирает контекст и готовит рабочий ответ специалисту." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=14;align=left;spacing=10" vertex="1" parent="1"><mxGeometry x="1970" y="330" width="270" height="150" as="geometry" /></mxCell>

        <mxCell id="doc_zone" value="Как хранить подробное описание блока внутри Draw.io" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf3ff;strokeColor=#4f81bd;fontSize=18;fontStyle=1;align=center;verticalAlign=top;spacingTop=14" vertex="1" parent="1">
          <mxGeometry x="370" y="570" width="1490" height="390" as="geometry" />
        </mxCell>
        <UserObject id="doc_tooltip" label="&lt;b&gt;Скриптовая фрагментация&lt;/b&gt;&lt;br&gt;A. Tooltip" tooltip="Короткая памятка: что делает скрипт, что не делает, где граница fragment, какие поля output обязательны." mode="tooltip">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4f81bd;fontSize=15;fontStyle=1" vertex="1" parent="1"><mxGeometry x="430" y="650" width="360" height="90" as="geometry" /></mxCell>
        </UserObject>
        <mxCell id="doc_tooltip_note" value="Для быстрого чтения при наведении. Сюда кладется короткое правило: скрипт режет raw-текст детерминированно, не чистит и не интерпретирует." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#4f81bd;fontSize=13;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="430" y="760" width="360" height="120" as="geometry" /></mxCell>

        <UserObject id="doc_metadata" label="&lt;b&gt;Скриптовая фрагментация&lt;/b&gt;&lt;br&gt;B. Metadata" owner="script" layer="raw" boundary_rules="speaker|timestamp|blank_line|hard_limit" output="fragment_id;raw_text;coordinates" limits="target 300-800; hard 1200">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4f81bd;fontSize=15;fontStyle=1" vertex="1" parent="1"><mxGeometry x="930" y="650" width="360" height="90" as="geometry" /></mxCell>
        </UserObject>
        <mxCell id="doc_metadata_note" value="Для формальной спецификации. Сюда кладутся machine-readable поля: boundary_rules, лимиты, запреты, output_fields, тип слоя raw." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#4f81bd;fontSize=13;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="930" y="760" width="360" height="120" as="geometry" /></mxCell>

        <UserObject id="doc_page" label="&lt;b&gt;Скриптовая фрагментация&lt;/b&gt;&lt;br&gt;C. Отдельная страница" tooltip="Полный регламент вынесен на вторую страницу этой схемы: 'Скриптовая фрагментация — регламент'.">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4f81bd;fontSize=15;fontStyle=1" vertex="1" parent="1"><mxGeometry x="1430" y="650" width="360" height="90" as="geometry" /></mxCell>
        </UserObject>
        <mxCell id="doc_page_note" value="Для полного регламента. Вторая страница хранит правила, формат output, проверки целостности и переход к LLM-очистке." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#4f81bd;fontSize=13;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="1430" y="760" width="360" height="120" as="geometry" /></mxCell>

        <mxCell id="bottom_note" value="Визуальное правило схемы: основной поток идёт слева направо одной линией. Обратные связи и регламенты не пересекают основной процесс." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;fontStyle=1;align=center" vertex="1" parent="1"><mxGeometry x="500" y="1040" width="1600" height="60" as="geometry" /></mxCell>

        <mxCell id="e12" edge="1" parent="1" source="phase_1" target="phase_2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#666666;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e23" edge="1" parent="1" source="phase_2" target="phase_3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#666666;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e34" edge="1" parent="1" source="phase_3" target="phase_4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#666666;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e45" edge="1" parent="1" source="phase_4" target="phase_5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#666666;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e56" edge="1" parent="1" source="phase_5" target="phase_6" value="утверждено" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#666666;fontSize=12;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e67" edge="1" parent="1" source="phase_6" target="phase_7" value="recall" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#666666;fontSize=12;"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="Скриптовая фрагментация — регламент" id="script-fragmentation-spec">
    <mxGraphModel dx="2200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="spec_title" value="Скриптовая фрагментация — полный регламент" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=28;fontStyle=1" vertex="1" parent="1"><mxGeometry x="320" y="30" width="1560" height="50" as="geometry" /></mxCell>
        <mxCell id="spec_intro" value="Этап выполняет скрипт, а не LLM. Его задача — создать стабильный raw-слой фрагментов, который можно однозначно привязать к месту в исходном тексте." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;fontStyle=1;align=center" vertex="1" parent="1"><mxGeometry x="350" y="100" width="1500" height="60" as="geometry" /></mxCell>
        <mxCell id="spec_1" value="1. Что делает скрипт&#xa;&#xa;• Делит исходный текст на стабильные raw fragments.&#xa;• Назначает ID [0001]–[9999].&#xa;• Сохраняет координаты: char, line, timestamps.&#xa;• Готовит детерминированный вход для LLM-этапа." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;align=left;spacing=12" vertex="1" parent="1"><mxGeometry x="70" y="220" width="470" height="210" as="geometry" /></mxCell>
        <mxCell id="spec_2" value="2. Что скрипт НЕ делает&#xa;&#xa;• Не выделяет психологический смысл.&#xa;• Не объединяет по теме.&#xa;• Не чистит ASR, пунктуацию и роли.&#xa;• Не переписывает и не сокращает.&#xa;• Не удаляет [пауза], [смех], [неразборчиво]." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;align=left;spacing=12" vertex="1" parent="1"><mxGeometry x="590" y="220" width="470" height="210" as="geometry" /></mxCell>
        <mxCell id="spec_3" value="3. Когда начинается новый fragment&#xa;&#xa;1) сменился speaker;&#xa;2) начался новый timestamp-блок;&#xa;3) при отсутствии speaker labels встретилась пустая строка между абзацами;&#xa;4) превышен hard limit.&#xa;&#xa;Одинарный перенос строки внутри той же реплики НЕ является новой границей." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;align=left;spacing=12" vertex="1" parent="1"><mxGeometry x="1110" y="220" width="980" height="210" as="geometry" /></mxCell>
        <mxCell id="spec_4" value="4. Базовая единица&#xa;&#xa;• Если есть speaker labels: базовая единица = реплика говорящего.&#xa;• Несколько строк одной реплики остаются в одном fragment.&#xa;• Если speaker labels нет: базовая единица = абзац, разделённый пустой строкой." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;align=left;spacing=12" vertex="1" parent="1"><mxGeometry x="70" y="500" width="600" height="220" as="geometry" /></mxCell>
        <mxCell id="spec_5" value="5. Длинная реплика&#xa;&#xa;Target: 300–800 символов. Hard limit: 1200 символов.&#xa;&#xa;Порядок split:&#xa;1) конец предложения (. ? ! …);&#xa;2) точка с запятой; 3) запятая; 4) пробел перед лимитом; 5) по символу.&#xa;&#xa;Связь частей хранится в metadata, не в номере." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;align=left;spacing=12" vertex="1" parent="1"><mxGeometry x="720" y="500" width="670" height="220" as="geometry" /></mxCell>
        <mxCell id="spec_6" value="6. Формат output fragment&#xa;&#xa;Обязательные поля:&#xa;fragment_id, source_id, speaker, raw_text, char_start, char_end, line_start, line_end, timestamp_start, timestamp_end.&#xa;&#xa;raw_text — точный кусок исходника, не очищенный текст." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;align=left;spacing=12" vertex="1" parent="1"><mxGeometry x="1440" y="500" width="650" height="220" as="geometry" /></mxCell>
        <mxCell id="spec_7" value="7. Проверки целостности&#xa;&#xa;• Все non-empty символы исходника попали ровно в один fragment.&#xa;• Нет потерь, дублей и наложений диапазонов.&#xa;• Нумерация непрерывная и уникальная.&#xa;• Каждый fragment восстанавливаем до места в исходнике.&#xa;• Один input → один и тот же output." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=15;align=left;spacing=12" vertex="1" parent="1"><mxGeometry x="70" y="790" width="1020" height="220" as="geometry" /></mxCell>
        <mxCell id="spec_8" value="8. Переход к LLM-очистке&#xa;&#xa;LLM получает не исходный монолит, а пакет raw fragments. Дальше LLM делает санитарную очистку, нормализацию и смысловую сборку, но обязана сохранять source_fragment_ids. Это мост между raw-слоем и semantic memory." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;align=left;spacing=12" vertex="1" parent="1"><mxGeometry x="1140" y="790" width="950" height="220" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>