        <mxCell id="zone_input" value="1. Источники данных" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=18;fontStyle=1;align=center;verticalAlign=top;spacingTop=12" vertex="1" parent="1">
